<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC1A1A1A"
    android:padding="8dp"
    android:elevation="999dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Status -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="●"
        android:textColor="#4CAF50"
        android:textSize="13sp"
        android:gravity="center"
        android:padding="3dp"
        android:layout_marginBottom="4dp"
        android:layout_gravity="center"/>

    <!-- Platzierungs-Buttons - GRÖSSER (von 48dp auf 56dp) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <Button
            android:id="@+id/btnSwipePlace"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="S"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4CAF50"
            android:textSize="20sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:layout_marginEnd="4dp"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnRefillPlace"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="R"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF9800"
            android:textSize="20sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Aktions-Buttons - GRÖSSER (von 34dp auf 40dp) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <Button
            android:id="@+id/btnSwipeNow"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="⬇"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00E676"
            android:textSize="15sp"
            android:padding="0dp"
            android:layout_marginEnd="3dp"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnRefillNow"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="R"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF1744"
            android:textSize="17sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:layout_marginEnd="3dp"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnStopAuto"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="⏹"
            android:textColor="#FFFFFF"
            android:backgroundTint="#D50000"
            android:textSize="15sp"
            android:padding="0dp"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Start-Button - GRÖSSER (von 32dp auf 38dp) -->
    <Button
        android:id="@+id/btnStartAuto"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:text="▶ START"
        android:textColor="#FFFFFF"
        android:backgroundTint="#F44336"
        android:textSize="14sp"
        android:textStyle="bold"
        android:padding="0dp"
        android:gravity="center"/>

    <!-- Koordinaten - GRÖSSER -->
    <TextView
        android:id="@+id/tvCoordinates"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#666666"
        android:textSize="9sp"
        android:gravity="center"
        android:padding="2dp"
        android:layout_marginTop="2dp"/>

    <!-- Lern-Status - GRÖSSER -->
    <TextView
        android:id="@+id/tvLearning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FFEB3B"
        android:textSize="9sp"
        android:gravity="center"
        android:padding="2dp"/>

</LinearLayout>
