<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#DD1A1A1A"
    android:padding="8dp"
    android:elevation="999dp"
    android:clickable="true"
    android:focusable="true"
    android:minWidth="200dp">

    <!-- Titel + Drag-Handle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#33FFFFFF"
        android:padding="4dp"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⬡ Lidl Refill"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⠿"
            android:textColor="#888888"
            android:textSize="16sp"/>
    </LinearLayout>

    <!-- Status - Größer -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✅ Bereit"
        android:textColor="#4CAF50"
        android:textSize="11sp"
        android:gravity="center"
        android:padding="4dp"
        android:background="#33000000"
        android:layout_marginBottom="2dp"/>

    <!-- Lern-Status -->
    <TextView
        android:id="@+id/tvLearning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📊 Lerne..."
        android:textColor="#FFEB3B"
        android:textSize="9sp"
        android:gravity="center"
        android:padding="2dp"
        android:background="#22000000"
        android:layout_marginBottom="4dp"/>

    <!-- Platzierungs-Buttons - Größer & Schöner -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="─── 📍 PLATZIERUNG ───"
        android:textColor="#4FC3F7"
        android:textSize="9sp"
        android:gravity="center"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="2dp">

        <Button
            android:id="@+id/btnSwipePlace"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="⬇ Swipe"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4CAF50"
            android:textSize="11sp"
            android:padding="0dp"
            android:layout_marginEnd="2dp"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnOcrPlace"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="📷 OCR"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2196F3"
            android:textSize="11sp"
            android:padding="0dp"
            android:layout_marginEnd="2dp"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnRefillPlace"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="🔄 Refill"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF9800"
            android:textSize="11sp"
            android:padding="0dp"
            android:stateListAnimator="@null"/>
    </LinearLayout>

    <!-- Aktions-Buttons - Größer & Schöner -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="─── ⚡ AKTIONEN ───"
        android:textColor="#4FC3F7"
        android:textSize="9sp"
        android:gravity="center"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="2dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="2dp">

        <Button
            android:id="@+id/btnSwipeNow"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:text="⬇ Swipe"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00E676"
            android:textSize="10sp"
            android:padding="0dp"
            android:layout_marginEnd="2dp"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnRefillNow"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:text="🔄 Refill"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF1744"
            android:textSize="10sp"
            android:padding="0dp"
            android:layout_marginEnd="2dp"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnOcrNow"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:text="📷 OCR"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2979FF"
            android:textSize="10sp"
            android:padding="0dp"
            android:layout_marginEnd="2dp"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnStopAuto"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:text="⏹ Stop"
            android:textColor="#FFFFFF"
            android:backgroundTint="#D50000"
            android:textSize="10sp"
            android:padding="0dp"
            android:stateListAnimator="@null"/>
    </LinearLayout>

    <!-- Start-Button - Größer -->
    <Button
        android:id="@+id/btnStartAuto"
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:text="▶ START AUTOMATIK"
        android:textColor="#FFFFFF"
        android:backgroundTint="#F44336"
        android:textSize="12sp"
        android:textStyle="bold"
        android:padding="0dp"
        android:layout_marginTop="4dp"
        android:stateListAnimator="@null"/>

    <!-- Koordinaten & Info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:background="#22000000"
        android:padding="2dp">

        <TextView
            android:id="@+id/tvCoordinates"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="(0,0)"
            android:textColor="#888888"
            android:textSize="8sp"
            android:gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Refill ≤ 0.30 GB"
            android:textColor="#FF1744"
            android:textSize="8sp"
            android:gravity="center"
            android:paddingStart="4dp"/>
    </LinearLayout>

</LinearLayout>
