<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC000000"
    android:padding="10dp"
    android:elevation="999dp"
    android:layout_marginTop="50dp">

    <!-- Status -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✅ Bereit"
        android:textColor="#4CAF50"
        android:textSize="12sp"
        android:gravity="center"
        android:padding="6dp"
        android:background="#33000000"
        android:layout_marginBottom="4dp"/>

    <!-- Platzierung -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="─── Platzierung ───"
        android:textColor="#FFEB3B"
        android:textSize="10sp"
        android:gravity="center"/>

    <Button
        android:id="@+id/btnSwipePlace"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⬇ Swipe platzieren"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4CAF50"
        android:textSize="12sp"
        android:layout_marginTop="2dp"/>

    <Button
        android:id="@+id/btnOcrPlace"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📷 OCR-Rechteck"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2196F3"
        android:textSize="12sp"
        android:layout_marginTop="2dp"/>

    <Button
        android:id="@+id/btnRefillPlace"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔄 Refill-Button"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF9800"
        android:textSize="12sp"
        android:layout_marginTop="2dp"/>

    <!-- Sofort-Aktionen -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="─── Sofort-Aktionen ───"
        android:textColor="#4FC3F7"
        android:textSize="10sp"
        android:gravity="center"
        android:layout_marginTop="6dp"/>

    <Button
        android:id="@+id/btnSwipeNow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⬇ Swipe jetzt"
        android:textColor="#FFFFFF"
        android:backgroundTint="#00E676"
        android:textSize="12sp"
        android:layout_marginTop="2dp"/>

    <Button
        android:id="@+id/btnRefillNow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔄 Refill jetzt"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF1744"
        android:textSize="12sp"
        android:layout_marginTop="2dp"/>

    <Button
        android:id="@+id/btnOcrNow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📷 OCR jetzt"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2979FF"
        android:textSize="12sp"
        android:layout_marginTop="2dp"/>

    <Button
        android:id="@+id/btnStopAuto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⏹ Stop"
        android:textColor="#FFFFFF"
        android:backgroundTint="#D50000"
        android:textSize="12sp"
        android:layout_marginTop="2dp"/>

    <Button
        android:id="@+id/btnStartAuto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="▶ Start"
        android:textColor="#FFFFFF"
        android:backgroundTint="#F44336"
        android:textSize="12sp"
        android:layout_marginTop="2dp"/>

    <TextView
        android:id="@+id/tvCoordinates"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pos: (0,0)"
        android:textColor="#CCCCCC"
        android:textSize="10sp"
        android:gravity="center"
        android:padding="4dp"
        android:background="#44000000"
        android:layout_marginTop="4dp"/>

</LinearLayout>
