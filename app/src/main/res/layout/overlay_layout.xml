<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:maxHeight="600dp"
    android:background="#CC000000"
    android:elevation="999dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Status-Anzeige -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ Bereit"
            android:textColor="#4CAF50"
            android:textSize="12sp"
            android:gravity="center"
            android:padding="6dp"
            android:background="#33000000"
            android:layout_marginBottom="4dp"/>

        <!-- ========== PLATZIERUNGS-BUTTONS ========== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="─── Platzierung ───"
            android:textColor="#FFEB3B"
            android:textSize="10sp"
            android:gravity="center"
            android:padding="2dp"
            android:layout_marginTop="4dp"/>

        <Button
            android:id="@+id/btnSwipePlace"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⬇ Swipe platzieren"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4CAF50"
            android:layout_marginTop="2dp"
            android:textSize="12sp"/>

        <Button
            android:id="@+id/btnOcrPlace"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📷 OCR-Rechteck"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2196F3"
            android:layout_marginTop="2dp"
            android:textSize="12sp"/>

        <Button
            android:id="@+id/btnRefillPlace"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔄 Refill-Button"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF9800"
            android:layout_marginTop="2dp"
            android:textSize="12sp"/>

        <!-- ========== SOFORT-AKTIONS-BUTTONS ========== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="─── Sofort-Aktionen ───"
            android:textColor="#4FC3F7"
            android:textSize="10sp"
            android:gravity="center"
            android:padding="2dp"
            android:layout_marginTop="6dp"/>

        <!-- 1. Swipe sofort ausführen -->
        <Button
            android:id="@+id/btnSwipeNow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⬇ Swipe jetzt"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00E676"
            android:layout_marginTop="2dp"
            android:textSize="12sp"/>

        <!-- 2. Refill sofort ausführen -->
        <Button
            android:id="@+id/btnRefillNow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔄 Refill jetzt"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF1744"
            android:layout_marginTop="2dp"
            android:textSize="12sp"/>

        <!-- 3. OCR sofort ausführen -->
        <Button
            android:id="@+id/btnOcrNow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📷 OCR jetzt"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2979FF"
            android:layout_marginTop="2dp"
            android:textSize="12sp"/>

        <!-- 4. Automation stoppen -->
        <Button
            android:id="@+id/btnStopAuto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏹ Stop"
            android:textColor="#FFFFFF"
            android:backgroundTint="#D50000"
            android:layout_marginTop="2dp"
            android:textSize="12sp"/>

        <!-- 5. Automation starten -->
        <Button
            android:id="@+id/btnStartAuto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶ Start"
            android:textColor="#FFFFFF"
            android:backgroundTint="#F44336"
            android:layout_marginTop="2dp"
            android:textSize="12sp"/>

        <!-- Koordinaten-Anzeige -->
        <TextView
            android:id="@+id/tvCoordinates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pos: (0,0)"
            android:textColor="#CCCCCC"
            android:textSize="10sp"
            android:gravity="center"
            android:padding="4dp"
            android:background="#44000000"
            android:layout_marginTop="4dp"/>

        <!-- Info-Text -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⬇ Swipe von oben nach unten"
            android:textColor="#FFEB3B"
            android:textSize="9sp"
            android:gravity="center"
            android:padding="2dp"
            android:layout_marginTop="2dp"/>

    </LinearLayout>
</ScrollView>
