<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC1A1A1A"
    android:padding="6dp"
    android:elevation="999dp"
    android:clickable="true"
    android:focusable="true"
    android:layout_gravity="bottom|end">

    <!-- Mini-Status -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="●"
        android:textColor="#4CAF50"
        android:textSize="10sp"
        android:gravity="center"
        android:padding="2dp"
        android:layout_marginBottom="4dp"
        android:layout_gravity="center"/>

    <!-- Runde Buttons - 3er Reihe -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <!-- S = Swipe platzieren -->
        <Button
            android:id="@+id/btnSwipePlace"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="S"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4CAF50"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:layout_marginEnd="4dp"
            android:stateListAnimator="@null"
            android:gravity="center"/>

        <!-- OCR = OCR platzieren -->
        <Button
            android:id="@+id/btnOcrPlace"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="OCR"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2196F3"
            android:textSize="12sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:layout_marginEnd="4dp"
            android:stateListAnimator="@null"
            android:gravity="center"/>

        <!-- R = Refill platzieren -->
        <Button
            android:id="@+id/btnRefillPlace"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="R"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF9800"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:stateListAnimator="@null"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Aktions-Buttons - 4er Reihe -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <!-- ⬇ = Swipe ausführen -->
        <Button
            android:id="@+id/btnSwipeNow"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="⬇"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00E676"
            android:textSize="14sp"
            android:padding="0dp"
            android:layout_marginEnd="3dp"
            android:stateListAnimator="@null"
            android:gravity="center"/>

        <!-- R = Refill ausführen -->
        <Button
            android:id="@+id/btnRefillNow"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="R"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF1744"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:layout_marginEnd="3dp"
            android:stateListAnimator="@null"
            android:gravity="center"/>

        <!-- OCR = OCR ausführen -->
        <Button
            android:id="@+id/btnOcrNow"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="📷"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2979FF"
            android:textSize="12sp"
            android:padding="0dp"
            android:layout_marginEnd="3dp"
            android:stateListAnimator="@null"
            android:gravity="center"/>

        <!-- ⏹ = Stop -->
        <Button
            android:id="@+id/btnStopAuto"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="⏹"
            android:textColor="#FFFFFF"
            android:backgroundTint="#D50000"
            android:textSize="12sp"
            android:padding="0dp"
            android:stateListAnimator="@null"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Start-Button - größer -->
    <Button
        android:id="@+id/btnStartAuto"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:text="▶ START"
        android:textColor="#FFFFFF"
        android:backgroundTint="#F44336"
        android:textSize="11sp"
        android:textStyle="bold"
        android:padding="0dp"
        android:stateListAnimator="@null"
        android:gravity="center"/>

    <!-- Koordinaten - klein -->
    <TextView
        android:id="@+id/tvCoordinates"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#666666"
        android:textSize="7sp"
        android:gravity="center"
        android:padding="1dp"
        android:layout_marginTop="2dp"/>

    <!-- Lern-Status - ganz klein -->
    <TextView
        android:id="@+id/tvLearning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FFEB3B"
        android:textSize="7sp"
        android:gravity="center"
        android:padding="1dp"/>

</LinearLayout>
