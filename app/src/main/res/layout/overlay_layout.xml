<!-- app/src/main/res/layout/overlay_layout.xml -->
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#D0000000"
    android:padding="8dp"
    android:elevation="100dp">

    <!-- Status-Anzeige -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🟢 Bereit"
        android:textColor="#4CAF50"
        android:textSize="12sp"
        android:gravity="center"
        android:padding="4dp"
        android:background="#33000000"/>

    <!-- Haupt-Buttons -->
    <Button
        android:id="@+id/btnSwipe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⬇ Swipe platzieren"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4CAF50"
        android:layout_marginTop="4dp"/>

    <Button
        android:id="@+id/btnOcr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📷 OCR-Rechteck"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2196F3"
        android:layout_marginTop="4dp"/>

    <Button
        android:id="@+id/btnRefill"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔄 Refill-Button"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF9800"
        android:layout_marginTop="4dp"/>

    <Button
        android:id="@+id/btnStart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="▶ Start"
        android:textColor="#FFFFFF"
        android:backgroundTint="#F44336"
        android:layout_marginTop="4dp"/>

    <!-- Koordinaten-Anzeige -->
    <TextView
        android:id="@+id/tvCoordinates"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pos: (0,0)"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:gravity="center"
        android:padding="2dp"
        android:background="#44000000"
        android:layout_marginTop="4dp"/>

</LinearLayout>
