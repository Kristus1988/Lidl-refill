<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC000000"
    android:padding="10dp"
    android:elevation="999dp">

    <!-- ===== STATUSZEILE ===== -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="● Bereit"
        android:textColor="#4CAF50"
        android:textSize="12sp"
        android:textStyle="bold"
        android:singleLine="true"/>

    <TextView
        android:id="@+id/tvCountdown"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⏱ Warte: --:--"
        android:textColor="#FFC107"
        android:textSize="11sp"
        android:singleLine="true"/>

    <TextView
        android:id="@+id/tvCycle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔄 0 Zyklen | ⬇ 0"
        android:textColor="#81D4FA"
        android:textSize="10sp"
        android:singleLine="true"/>

    <TextView
        android:id="@+id/tvOcrResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📸 OCR: --"
        android:textColor="#FFB74D"
        android:textSize="10sp"
        android:singleLine="true"
        android:layout_marginBottom="4dp"/>

    <!-- ===== SPINNER (weiß umrandet + weiße Schrift) ===== -->
    <Spinner
        android:id="@+id/spinnerConsumption"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/spinner_border"
        android:popupBackground="#333333"
        android:textColor="#FFFFFF"
        android:padding="4dp"/>

    <!-- ===== POSITIONIERUNGS-BUTTONS ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <!-- Swipe Positionierung - GELB -->
        <Button
            android:id="@+id/btnSwipePlace"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="⬇ Swipe"
            android:textSize="11sp"
            android:backgroundTint="#FFC107"
            android:textColor="#000000"
            android:layout_marginEnd="2dp"
            android:padding="2dp"/>

        <!-- Refill Positionierung - BLAU -->
        <Button
            android:id="@+id/btnRefillPlace"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="🔵 Refill"
            android:textSize="11sp"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:padding="4dp"/>

        <!-- Crop - ORANGE -->
        <Button
            android:id="@+id/btnCrop"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="✂️ Crop"
            android:textSize="11sp"
            android:backgroundTint="#FF6F00"
            android:textColor="#FFFFFF"
            android:layout_marginStart="2dp"
            android:padding="2dp"/>
    </LinearLayout>

    <!-- ===== TEST-BUTTONS ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <!-- Swipe Test - GELB -->
        <Button
            android:id="@+id/btnSwipeTest"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="S Test"
            android:textSize="11sp"
            android:backgroundTint="#FFC107"
            android:textColor="#000000"
            android:layout_marginEnd="2dp"
            android:padding="2dp"/>

        <!-- Refill Test - BLAU -->
        <Button
            android:id="@+id/btnRefillTest"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="R Test"
            android:textSize="11sp"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:padding="2dp"/>

        <!-- OCR - ORANGE -->
        <Button
            android:id="@+id/btnOcrNow"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="📸 OCR"
            android:textSize="11sp"
            android:backgroundTint="#FF6F00"
            android:textColor="#FFFFFF"
            android:layout_marginStart="2dp"
            android:padding="2dp"/>
    </LinearLayout>

    <!-- ===== AUTOMATIK-BUTTONS ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <!-- Start - GRÜN -->
        <Button
            android:id="@+id/btnStartAuto"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="▶ Start"
            android:textSize="11sp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="2dp"
            android:padding="2dp"/>

        <!-- Stop - ROT -->
        <Button
            android:id="@+id/btnStopAuto"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="⏹ Stop"
            android:textSize="11sp"
            android:backgroundTint="#F44336"
            android:textColor="#FFFFFF"
            android:enabled="false"
            android:layout_marginStart="2dp"
            android:padding="2dp"/>
    </LinearLayout>

    <!-- ===== SCHLIEßEN-BUTTON ===== -->
    <Button
        android:id="@+id/btnClose"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:text="✕ Schließen"
        android:textSize="11sp"
        android:backgroundTint="#F44336"
        android:textColor="#FFFFFF"
        android:padding="2dp"/>

</LinearLayout>
