<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC1A1A1A"
    android:padding="6dp"
    android:elevation="999dp"
    android:clickable="true"
    android:focusable="true">

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="●"
        android:textColor="#4CAF50"
        android:textSize="11sp"
        android:gravity="center"
        android:padding="2dp"
        android:layout_marginBottom="2dp"
        android:layout_gravity="center"/>

    <!-- Platzierungs-Buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="2dp">

        <Button
            android:id="@+id/btnSwipePlace"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="S"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4CAF50"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:layout_marginEnd="3dp"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnOcrPlace"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="OCR"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2196F3"
            android:textSize="12sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:layout_marginEnd="3dp"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnRefillPlace"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="R"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF9800"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Aktions-Buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="2dp">

        <Button
            android:id="@+id/btnSwipeNow"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:text="⬇"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00E676"
            android:textSize="13sp"
            android:padding="0dp"
            android:layout_marginEnd="2dp"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnRefillNow"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:text="R"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF1744"
            android:textSize="15sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:layout_marginEnd="2dp"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnOcrNow"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:text="📷"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2979FF"
            android:textSize="13sp"
            android:padding="0dp"
            android:layout_marginEnd="2dp"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnStopAuto"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:text="⏹"
            android:textColor="#FFFFFF"
            android:backgroundTint="#D50000"
            android:textSize="13sp"
            android:padding="0dp"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Start-Button -->
    <Button
        android:id="@+id/btnStartAuto"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:text="▶ START"
        android:textColor="#FFFFFF"
        android:backgroundTint="#F44336"
        android:textSize="12sp"
        android:textStyle="bold"
        android:padding="0dp"
        android:gravity="center"/>

    <!-- Info -->
    <TextView
        android:id="@+id/tvCoordinates"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#666666"
        android:textSize="7sp"
        android:gravity="center"
        android:padding="1dp"
        android:layout_marginTop="1dp"/>

    <TextView
        android:id="@+id/tvLearning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FFEB3B"
        android:textSize="7sp"
        android:gravity="center"
        android:padding="1dp"/>

</LinearLayout>
