<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC000000"
    android:padding="14dp"
    android:elevation="999dp">

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="● Bereit"
        android:textColor="#4CAF50"
        android:textSize="14sp"
        android:textStyle="bold"
        android:singleLine="true"/>

    <TextView
        android:id="@+id/tvCountdown"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⏱ Warte: --:--"
        android:textColor="#FFC107"
        android:textSize="13sp"
        android:singleLine="true"/>

    <TextView
        android:id="@+id/tvCycle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔄 0 Zyklen | ⬇ 0"
        android:textColor="#81D4FA"
        android:textSize="12sp"
        android:singleLine="true"/>

    <TextView
        android:id="@+id/tvOcrResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📸 OCR: --"
        android:textColor="#FFB74D"
        android:textSize="12sp"
        android:singleLine="true"
        android:layout_marginBottom="6dp"/>

    <Spinner
        android:id="@+id/spinnerConsumption"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginBottom="6dp"
        android:background="@drawable/spinner_border"
        android:popupBackground="#333333"
        android:textColor="#FFFFFF"
        android:padding="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <Button
            android:id="@+id/btnSwipePlace"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="⬇ Swipe"
            android:textSize="12sp"
            android:backgroundTint="#FFC107"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="3dp"
            android:padding="4dp"/>

        <Button
            android:id="@+id/btnRefillPlace"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="🔵 Refill"
            android:textSize="12sp"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            android:padding="4dp"/>

        <Button
            android:id="@+id/btnCrop"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="✂️ Crop"
            android:textSize="12sp"
            android:backgroundTint="#FF6F00"
            android:textColor="#FFFFFF"
            android:layout_marginStart="3dp"
            android:padding="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <Button
            android:id="@+id/btnSwipeTest"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="S Test"
            android:textSize="12sp"
            android:backgroundTint="#FFC107"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="3dp"
            android:padding="4dp"/>

        <Button
            android:id="@+id/btnRefillTest"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="R Test"
            android:textSize="12sp"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            android:padding="4dp"/>

        <Button
            android:id="@+id/btnOcrNow"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="📸 OCR"
            android:textSize="12sp"
            android:backgroundTint="#FF6F00"
            android:textColor="#FFFFFF"
            android:layout_marginStart="3dp"
            android:padding="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <Button
            android:id="@+id/btnStartAuto"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="▶ Start"
            android:textSize="12sp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="3dp"
            android:padding="4dp"/>

        <Button
            android:id="@+id/btnStopAuto"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="⏹ Stop"
            android:textSize="12sp"
            android:backgroundTint="#F44336"
            android:textColor="#FFFFFF"
            android:enabled="false"
            android:layout_marginStart="3dp"
            android:padding="4dp"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnClose"
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:text="✕ Schließen"
        android:textSize="12sp"
        android:backgroundTint="#F44336"
        android:textColor="#FFFFFF"
        android:padding="4dp"/>

</LinearLayout>
