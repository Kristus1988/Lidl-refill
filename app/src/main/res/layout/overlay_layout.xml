<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC1A1A1A"
    android:padding="10dp"
    android:elevation="999dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Status - größer -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="●"
        android:textColor="#4CAF50"
        android:textSize="15sp"
        android:gravity="center"
        android:padding="4dp"
        android:layout_marginBottom="4dp"
        android:layout_gravity="center"/>

    <!-- Verbrauchs-Auswahl -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📊 VERBRAUCH:"
        android:textColor="#4FC3F7"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginBottom="2dp"/>

    <Spinner
        android:id="@+id/spinnerConsumption"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="#33000000"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:layout_marginBottom="4dp"/>

    <!-- Platzierungs-Buttons - GRÖSSER -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <Button
            android:id="@+id/btnSwipePlace"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text="S"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4CAF50"
            android:textSize="24sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:layout_marginEnd="4dp"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnRefillPlace"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text="R"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF9800"
            android:textSize="24sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Aktions-Buttons - GRÖSSER -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <Button
            android:id="@+id/btnSwipeNow"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:text="⬇"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00E676"
            android:textSize="18sp"
            android:padding="0dp"
            android:layout_marginEnd="3dp"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnRefillNow"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:text="R"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF1744"
            android:textSize="20sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:layout_marginEnd="3dp"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnStopAuto"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:text="⏹"
            android:textColor="#FFFFFF"
            android:backgroundTint="#D50000"
            android:textSize="18sp"
            android:padding="0dp"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Start-Button - GRÖSSER -->
    <Button
        android:id="@+id/btnStartAuto"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="▶ START"
        android:textColor="#FFFFFF"
        android:backgroundTint="#F44336"
        android:textSize="16sp"
        android:textStyle="bold"
        android:padding="0dp"
        android:gravity="center"/>

    <!-- Koordinaten - GRÖSSER -->
    <TextView
        android:id="@+id/tvCoordinates"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#666666"
        android:textSize="10sp"
        android:gravity="center"
        android:padding="2dp"
        android:layout_marginTop="2dp"/>

    <!-- Lern-Status - GRÖSSER -->
    <TextView
        android:id="@+id/tvLearning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FFEB3B"
        android:textSize="10sp"
        android:gravity="center"
        android:padding="2dp"/>

</LinearLayout>
