<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:maxHeight="600dp"
        android:background="@android:color/black"
        android:padding="8dp"
        android:elevation="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- Status Anzeige -->
            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🟢 Bereit"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:padding="8dp"
                android:background="#333333"
                android:gravity="center" />

            <!-- Countdown Anzeige -->
            <TextView
                android:id="@+id/countdownText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⏳ Bereit"
                android:textColor="#FFC107"
                android:textSize="14sp"
                android:padding="8dp"
                android:gravity="center" />

            <!-- OCR Ergebnis -->
            <TextView
                android:id="@+id/ocrResultText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📊 ---"
                android:textColor="#4CAF50"
                android:textSize="16sp"
                android:textStyle="bold"
                android:padding="8dp"
                android:gravity="center"
                android:background="#1a1a1a" />

            <!-- Mode Spinner -->
            <Spinner
                android:id="@+id/modeSpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/spinner_border"
                android:popupBackground="@android:color/black"
                android:entries="@array/mode_entries" />

            <!-- Button Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btnSwipe"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="👆 Swipe"
                    android:textColor="@android:color/white"
                    android:background="#FFC107"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnRefill"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="🔄 Refill"
                    android:textColor="@android:color/white"
                    android:background="#2196F3"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <Button
                    android:id="@+id/btnCrop"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="✂️ Crop &amp; OCR"
                    android:textColor="@android:color/white"
                    android:background="#FF6F00"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnStartStop"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="▶️ Start"
                    android:textColor="@android:color/white"
                    android:background="#4CAF50"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- Close Button -->
            <Button
                android:id="@+id/btnClose"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:text="❌ Schließen"
                android:textColor="@android:color/white"
                android:background="#F44336" />

        </LinearLayout>
    </ScrollView>

    <!-- Crop Overlay - Vereinfacht (ohne Drawables) -->
    <FrameLayout
        android:id="@+id/cropOverlay"
        android:layout_width="300dp"
        android:layout_height="150dp"
        android:visibility="gone"
        android:background="#44FF0000"
        android:clickable="true">

        <!-- Crop Handle Top-Left -->
        <View
            android:id="@+id/cropHandleTL"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="top|start"
            android:background="#FFFFFF"
            android:elevation="8dp"
            android:layout_marginLeft="-8dp"
            android:layout_marginTop="-8dp" />

        <!-- Crop Handle Bottom-Right -->
        <View
            android:id="@+id/cropHandleBR"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="bottom|end"
            android:background="#FFFFFF"
            android:elevation="8dp"
            android:layout_marginRight="-8dp"
            android:layout_marginBottom="-8dp" />

    </FrameLayout>

</FrameLayout>
