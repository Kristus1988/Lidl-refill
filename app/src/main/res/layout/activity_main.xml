<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔄 Lidl Refill"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Automatisches 1GB Aufladen"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="30dp"/>

    <TextView
        android:id="@+id/tvPermissionStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📋 Berechtigungen werden geprüft..."
        android:textSize="12sp"
        android:background="#F5F5F5"
        android:padding="12dp"
        android:layout_marginBottom="20dp"
        android:lineSpacingExtra="4dp"/>

    <!-- ===== BEREITS VORHANDENE BUTTONS ===== -->
    <Button
        android:id="@+id/btnRequestPermissions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔓 Overlay &amp; Accessibility aktivieren"
        android:backgroundTint="#2196F3"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btnCheckPermissions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✅ Berechtigungen prüfen"
        android:backgroundTint="#FF9800"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btnRefreshAccessibility"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔄 Accessibility refresh (Honor)"
        android:backgroundTint="#E91E63"
        android:layout_marginBottom="10dp"
        android:textColor="#FFFFFF"/>

    <!-- ===== NEUER BUTTON FÜR SCREEN-CAPTURE ===== -->
    <Button
        android:id="@+id/btnRequestScreenCapture"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📸 Screen-Capture aktivieren (OCR)"
        android:backgroundTint="#FF6F00"
        android:layout_marginBottom="10dp"
        android:textColor="#FFFFFF"/>

    <Button
        android:id="@+id/btnRestartApp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔄 App neu starten"
        android:backgroundTint="#9C27B0"
        android:layout_marginBottom="10dp"
        android:textColor="#FFFFFF"/>

    <Button
        android:id="@+id/btnStartService"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🚀 Overlay starten"
        android:backgroundTint="#4CAF50"
        android:layout_marginBottom="20dp"
        android:enabled="false"/>

    <!-- ===== WARNUNG ===== -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="\n⚠️ Die App funktioniert über ALLEN Apps!\nSogar über dem Sperrbildschirm."
        android:textSize="12sp"
        android:textColor="#D32F2F"
        android:gravity="center"
        android:background="#FFEBEE"
        android:padding="10dp"
        android:layout_marginTop="20dp"/>

</LinearLayout>
