<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- Header -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp"
            android:background="#1E1E1E"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛒 Lidl Connect Refill"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#4FC3F7" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Automatische Aufladung via Accessibility"
                android:textSize="11sp"
                android:textColor="#B0BEC5" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Statusbereich -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#1E1E1E"
        android:elevation="4dp">

        <!-- Service-Status -->
        <TextView
            android:id="@+id/tv_service_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="❌ Service INAKTIV – Bitte aktivieren!"
            android:textSize="14sp"
            android:textColor="#F44336"
            android:gravity="center"
            android:padding="8dp"
            android:background="#2C2C2C"
            android:layout_marginBottom="8dp"
            android:visibility="visible" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔄 Bereit..."
            android:textSize="14sp"
            android:textColor="#B0BEC5"
            android:gravity="center" />

        <ProgressBar
            android:id="@+id/progress_status"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#4FC3F7"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tv_volume"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📦 Inklusiv: -- GB / 25 GB"
                android:textSize="12sp"
                android:textColor="#4FC3F7" />

            <TextView
                android:id="@+id/tv_refill"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔄 Refill: -- GB"
                android:textSize="12sp"
                android:textColor="#FFB300"
                android:textAlignment="textEnd" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_refill_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔄 Refills: 0"
                android:textSize="12sp"
                android:textColor="#B0BEC5" />

            <TextView
                android:id="@+id/tv_next_check"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⏱️ --"
                android:textSize="12sp"
                android:textColor="#78909C"
                android:textAlignment="textEnd" />
        </LinearLayout>

        <!-- Buttons Reihe 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn_open_settings"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="⚙️ Service aktivieren"
                android:backgroundTint="#FF9800"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn_manual_select"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="📝 Manuell auswählen"
                android:backgroundTint="#9C27B0"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Buttons Reihe 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <Button
                android:id="@+id/btn_open_app"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="📱 Lidl App öffnen"
                android:backgroundTint="#2196F3"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn_start"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="▶️ Start"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn_stop"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="⏹️ Stop"
                android:backgroundTint="#F44336"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
