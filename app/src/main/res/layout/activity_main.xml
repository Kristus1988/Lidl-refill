<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="0dp">

    <!-- ============ WEBVIEW + OVERLAY ============ -->
    <FrameLayout
        android:id="@+id/overlayContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2"
        android:background="#FFFFFF">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible"/>

    </FrameLayout>

    <!-- ============ APP-BEREICH (UNTEN) ============ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.8"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#F5F5F5"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔄 Lidl Refill"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Automatisches 1GB Aufladen"
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp"/>

        <!-- VOLUMEN-ANZEIGE -->
        <TextView
            android:id="@+id/tvVolumeStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 Volumen wird geladen..."
            android:textSize="13sp"
            android:background="#E8F5E9"
            android:padding="10dp"
            android:layout_marginBottom="8dp"
            android:lineSpacingExtra="4dp"
            android:textColor="#333333"/>

        <!-- REFILL-POSITION -->
        <TextView
            android:id="@+id/tvRefillPos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 Refill: nicht platziert"
            android:textSize="11sp"
            android:gravity="center"
            android:background="#FFF3E0"
            android:padding="6dp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnSetRefillPos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📍 Refill positionieren"
                android:backgroundTint="#FF9800"
                android:textSize="12sp"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btnCheckVolume"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📊 Volumen"
                android:backgroundTint="#2196F3"
                android:textSize="12sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnStartAuto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="▶ START"
                android:backgroundTint="#4CAF50"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btnStopAuto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⏹ STOP"
                android:backgroundTint="#D50000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:enabled="false"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ Refill-Button positionieren (roter Kreis) und START"
            android:textSize="9sp"
            android:textColor="#4CAF50"
            android:gravity="center"
            android:background="#E8F5E9"
            android:padding="4dp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>
</LinearLayout>
