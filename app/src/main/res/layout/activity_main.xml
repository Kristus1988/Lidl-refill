<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- Header -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#1E1E1E"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛒 Lidl Connect Refill"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#4FC3F7" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Automatische Aufladung"
                android:textSize="12sp"
                android:textColor="#B0BEC5" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- WebView (unsichtbar, läuft im Hintergrund) -->
    <WebView
        android:id="@+id/webview_lidl"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <!-- Statusanzeige -->
    <LinearLayout
        android:id="@+id/layout_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#1E1E1E"
        android:visibility="visible">

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔄 Bereit"
            android:textSize="14sp"
            android:textColor="#B0BEC5"
            android:gravity="center" />

        <ProgressBar
            android:id="@+id/progress_status"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#4FC3F7"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_volume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📦 Inklusiv: -- GB / 25 GB"
            android:textSize="13sp"
            android:textColor="#4FC3F7"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tv_refill"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔄 Refill: -- GB"
            android:textSize="13sp"
            android:textColor="#FFB300"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tv_refill_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔄 Refills: 0"
            android:textSize="13sp"
            android:textColor="#B0BEC5"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Steuerung -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#1E1E1E"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/et_username"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:hint="Telefonnummer"
            android:textColor="#E0E0E0"
            android:textColorHint="#78909C"
            android:background="@android:drawable/editbox_background"
            android:padding="8dp"
            android:layout_marginEnd="8dp"
            android:inputType="phone" />

        <EditText
            android:id="@+id/et_password"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:hint="Passwort"
            android:textColor="#E0E0E0"
            android:textColorHint="#78909C"
            android:background="@android:drawable/editbox_background"
            android:padding="8dp"
            android:inputType="textPassword" />

        <Button
            android:id="@+id/btn_start"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="▶️ Start"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btn_stop"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="⏹️ Stop"
            android:backgroundTint="#F44336"
            android:textColor="#FFFFFF"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="13sp"
            android:layout_marginStart="4dp" />
    </LinearLayout>

</LinearLayout>
