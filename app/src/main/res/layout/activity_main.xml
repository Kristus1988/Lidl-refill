<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:gravity="center"
    android:padding="20dp">

    <!-- Logo/Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🛒"
        android:textSize="48sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lidl Refill"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#4FC3F7"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Automatischer Refill"
        android:textSize="13sp"
        android:textColor="#78909C"
        android:layout_marginBottom="30dp" />

    <!-- Status -->
    <TextView
        android:id="@+id/tv_service_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="❌ Service inaktiv"
        android:textSize="14sp"
        android:textColor="#F44336"
        android:gravity="center"
        android:padding="10dp"
        android:background="#2C2C2C"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔴 Gestoppt"
        android:textSize="14sp"
        android:textColor="#B0BEC5"
        android:gravity="center"
        android:layout_marginBottom="20dp" />

    <!-- 🔵 Position aufnehmen (einziger Button!) -->
    <Button
        android:id="@+id/btn_start_recording"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="📌 Position aufnehmen"
        android:backgroundTint="#9C27B0"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <!-- 📱 Lidl öffnen -->
    <Button
        android:id="@+id/btn_open_app"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="📱 Lidl öffnen"
        android:backgroundTint="#2196F3"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- Info -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1. Position aufnehmen\n2. Lidl öffnen\n3. Start im Overlay"
        android:textSize="11sp"
        android:textColor="#546E7A"
        android:gravity="center"
        android:layout_marginTop="20dp" />

</LinearLayout>
