<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="0dp">

    <!-- ============ WEBVIEW (NUR 50% des Bildschirms) ============ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.5"
        android:background="#FFFFFF">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"/>

    </FrameLayout>

    <!-- ============ APP-BEREICH (UNTERE HÄLFTE) ============ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.5"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="#F5F5F5"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔄 Lidl Refill"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Automatisches 1GB Aufladen"
            android:textSize="10sp"
            android:textColor="#666666"
            android:layout_marginBottom="4dp"/>

        <!-- VOLUMEN-ANZEIGE -->
        <TextView
            android:id="@+id/tvVolumeStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 Volumen wird geladen..."
            android:textSize="11sp"
            android:background="#E8F5E9"
            android:padding="6dp"
            android:layout_marginBottom="4dp"
            android:lineSpacingExtra="2dp"
            android:textColor="#333333"/>

        <Button
            android:id="@+id/btnCheckVolume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 Volumen prüfen"
            android:backgroundTint="#4CAF50"
            android:layout_marginBottom="4dp"
            android:textSize="11sp"/>

        <!-- PERMISSION STATUS -->
        <TextView
            android:id="@+id/tvPermissionStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 Berechtigungen werden geprüft..."
            android:textSize="9sp"
            android:background="#F5F5F5"
            android:padding="4dp"
            android:layout_marginBottom="4dp"
            android:lineSpacingExtra="1dp"/>

        <!-- BUTTONS - ZWEI REIHEN (kleiner) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="2dp">

            <Button
                android:id="@+id/btnRequestPermissions"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔓 Berechtigungen"
                android:backgroundTint="#2196F3"
                android:textSize="9sp"
                android:layout_marginEnd="2dp"/>

            <Button
                android:id="@+id/btnCheckPermissions"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="✅ Prüfen"
                android:backgroundTint="#FF9800"
                android:textSize="9sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="2dp">

            <Button
                android:id="@+id/btnRefreshAccessibility"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔄 Accessibility"
                android:backgroundTint="#E91E63"
                android:textSize="9sp"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="2dp"/>

            <Button
                android:id="@+id/btnRestartApp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔄 App neu"
                android:backgroundTint="#9C27B0"
                android:textSize="9sp"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnStartService"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚀 Overlay starten"
            android:backgroundTint="#4CAF50"
            android:layout_marginBottom="2dp"
            android:textSize="11sp"
            android:enabled="false"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📌 Einmalig auf der Webseite anmelden"
            android:textSize="8sp"
            android:textColor="#4CAF50"
            android:gravity="center"
            android:background="#E8F5E9"
            android:padding="2dp"/>

    </LinearLayout>
</LinearLayout>
