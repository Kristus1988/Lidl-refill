<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="0dp">

    <!-- ============ WEBVIEW ============ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2"
        android:background="#FFFFFF">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible"/>

    </FrameLayout>

    <!-- ============ APP-BEREICH ============ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.8"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#F5F5F5"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔄 Lidl Refill"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Automatisches 1GB Aufladen"
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp"/>

        <!-- ============ VERBRAUCHS-AUSWAHL ============ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 VERBRAUCH:"
            android:textSize="11sp"
            android:textColor="#333333"
            android:gravity="center"
            android:layout_marginBottom="4dp"/>

        <Spinner
            android:id="@+id/spinnerConsumption"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <!-- VOLUMEN-ANZEIGE -->
        <TextView
            android:id="@+id/tvVolumeStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 Verbrauch: Standard (17-20 Min)"
            android:textSize="12sp"
            android:background="#E8F5E9"
            android:padding="8dp"
            android:layout_marginBottom="8dp"
            android:lineSpacingExtra="4dp"
            android:textColor="#333333"/>

        <Button
            android:id="@+id/btnCheckVolume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔄 WebView aktualisieren"
            android:backgroundTint="#2196F3"
            android:layout_marginBottom="8dp"
            android:textSize="14sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnStartAuto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="▶ START"
                android:backgroundTint="#4CAF50"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btnStopAuto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⏹ STOP"
                android:backgroundTint="#D50000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:enabled="false"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ Refill-Button wird automatisch erkannt und menschlich geklickt"
            android:textSize="9sp"
            android:textColor="#4CAF50"
            android:gravity="center"
            android:background="#E8F5E9"
            android:padding="4dp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>
</LinearLayout>
