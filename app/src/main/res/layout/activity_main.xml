<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔄 Lidl Refill"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Automatisches 1GB Aufladen"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="30dp"/>

        <!-- VOLUMEN-ANZEIGE -->
        <TextView
            android:id="@+id/tvVolumeStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 Volumen wird geladen..."
            android:textSize="14sp"
            android:background="#E8F5E9"
            android:padding="12dp"
            android:layout_marginBottom="20dp"
            android:lineSpacingExtra="4dp"
            android:textColor="#333333"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btnCheckVolume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 Volumen prüfen"
            android:backgroundTint="#4CAF50"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/tvPermissionStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 Berechtigungen werden geprüft..."
            android:textSize="12sp"
            android:background="#F5F5F5"
            android:padding="12dp"
            android:layout_marginBottom="20dp"
            android:lineSpacingExtra="4dp"/>

        <Button
            android:id="@+id/btnRequestPermissions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔓 Berechtigungen erteilen"
            android:backgroundTint="#2196F3"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btnCheckPermissions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ Berechtigungen prüfen"
            android:backgroundTint="#FF9800"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btnRefreshAccessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔄 Accessibility refresh"
            android:backgroundTint="#E91E63"
            android:layout_marginBottom="10dp"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnRestartApp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔄 App neu starten"
            android:backgroundTint="#9C27B0"
            android:layout_marginBottom="10dp"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnStartService"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚀 Overlay starten"
            android:backgroundTint="#4CAF50"
            android:layout_marginBottom="20dp"
            android:enabled="false"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📌 WEBVIEW-MODUS:"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#4CAF50"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔑 Einmalig auf der Webseite anmelden\n📊 Volumen wird automatisch erkannt\n✅ Kein Screen-Capture nötig!\n⏱ Refill alle 15-20 Minuten"
            android:textSize="13sp"
            android:textColor="#555555"
            android:background="#E8F5E9"
            android:padding="12dp"
            android:lineSpacingExtra="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\n⚠️ Die App funktioniert über ALLEN Apps!"
            android:textSize="12sp"
            android:textColor="#D32F2F"
            android:gravity="center"
            android:background="#FFEBEE"
            android:padding="10dp"
            android:layout_marginTop="20dp"/>

    </LinearLayout>
</ScrollView>
