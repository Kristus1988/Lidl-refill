<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#121212">

    <!-- Header -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="#1E1E1E"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👆 Lidl Refill Helper"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#4FC3F7" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ziehe die Felder auf die Lidl App"
                android:textSize="12sp"
                android:textColor="#B0BEC5" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Status -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#1E1E1E">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 Status"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#E0E0E0" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⏳ Warte auf Start..."
                android:textSize="13sp"
                android:textColor="#B0BEC5"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tv_volume"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📦 Volumen: -- GB"
                android:textSize="13sp"
                android:textColor="#4FC3F7"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tv_refill_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔄 Refills: 0"
                android:textSize="13sp"
                android:textColor="#FFB300"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tv_next_check"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⏱️ Nächste Prüfung: --"
                android:textSize="13sp"
                android:textColor="#78909C"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/btn_start"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="▶️ Overlay aktivieren"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_stop"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="⏹️ Overlay deaktivieren"
            android:backgroundTint="#F44336"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ℹ️ Ziehe den 🔵 Kreis auf den Refill-Button und das 🟦 Rechteck auf die Volumen-Anzeige. Die App überwacht dann automatisch."
        android:textSize="11sp"
        android:textColor="#78909C"
        android:gravity="center"
        android:layout_marginTop="16dp" />

</LinearLayout>
