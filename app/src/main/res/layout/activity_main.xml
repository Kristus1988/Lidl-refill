<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- Header -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#1E1E1E"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛒 Lidl Connect Refill"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#4FC3F7" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Automatische Aufladung"
                android:textSize="12sp"
                android:textColor="#B0BEC5" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- WebView (unsichtbar, läuft im Hintergrund) -->
    <WebView
        android:id="@+id/webview_lidl"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <!-- Statusanzeige -->
    <LinearLayout
        android:id="@+id/layout_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#1E1E1E"
        android:visibility="visible">

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔄 Bereit"
            android:textSize="14sp"
            android:textColor="#B0BEC5"
            android:gravity="center" />

        <ProgressBar
            android:id="@+id/progress_status"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#4FC3F7"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_volume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📦 Inklusiv: -- GB / 25 GB"
            android:textSize="13sp"
            android:textColor="#4FC3F7"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tv_refill"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔄 Refill: -- GB"
            android:textSize="13sp"
            android:textColor="#FFB300"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tv_refill_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔄 Refills: 0"
            android:textSize="13sp"
            android:textColor="#B0BEC5"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Steuerung (Eingabefelder jetzt besser sichtbar!) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#2A2A2A"
        android:elevation="8dp">

        <!-- Telefonnummer -->
        <EditText
            android:id="@+id/et_username"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Telefonnummer (z.B. 01749995818)"
            android:textColor="#FFFFFF"
            android:textColorHint="#B0BEC5"
            android:background="@drawable/edittext_border"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:inputType="phone"
            android:textSize="14sp"
            android:importantForAutofill="no" />

        <!-- Passwort -->
        <EditText
            android:id="@+id/et_password"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Passwort"
            android:textColor="#FFFFFF"
            android:textColorHint="#B0BEC5"
            android:background="@drawable/edittext_border"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:inputType="textPassword"
            android:textSize="14sp"
            android:importantForAutofill="no" />

        <!-- Buttons (groß und auffällig) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_start"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="▶️ START"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_stop"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="⏹️ STOP"
                android:backgroundTint="#F44336"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
