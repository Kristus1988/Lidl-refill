<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/overlay_background"
    android:padding="12dp"
    android:elevation="10dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Status + Refills -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_overlay_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔄 AKTIV"
            android:textSize="11sp"
            android:textColor="#4CAF50"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_overlay_refills"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔄 0"
            android:textSize="11sp"
            android:textColor="#B0BEC5" />
    </LinearLayout>

    <!-- Volumen + Countdown -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="2dp">

        <TextView
            android:id="@+id/tv_overlay_volume"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📊 0.00 GB"
            android:textSize="15sp"
            android:textColor="#4FC3F7"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_overlay_next_check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏱️ --"
            android:textSize="12sp"
            android:textColor="#FFB300" />
    </LinearLayout>

    <!-- Buttons: Pause + Stop + Refresh -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp">

        <Button
            android:id="@+id/btn_overlay_pause"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:text="⏸️"
            android:textSize="13sp"
            android:backgroundTint="#FF9800"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="4dp"
            android:padding="0dp" />

        <Button
            android:id="@+id/btn_overlay_stop"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:text="⏹️"
            android:textSize="13sp"
            android:backgroundTint="#F44336"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="4dp"
            android:padding="0dp" />

        <Button
            android:id="@+id/btn_overlay_refresh"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:text="🔄"
            android:textSize="13sp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:padding="0dp" />
    </LinearLayout>

</LinearLayout>
